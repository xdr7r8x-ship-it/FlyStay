# ===========================================
# FlyStay Production Environment Variables
# ===========================================
# DO NOT commit real credentials
# DO NOT log these values

# ===========================================
# DATABASE (PostgreSQL - Required)
# ===========================================
DATABASE_URL="postgresql://user:password@host:5432/flystay?sslmode=require"

# ===========================================
# JWT Authentication (Required)
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-min-32-characters"

# ===========================================
# Application URL
# ===========================================
NEXT_PUBLIC_APP_URL="https://flystay.com"

# ===========================================
# ADMIN USER (for seeding)
# ===========================================
ADMIN_EMAIL="admin@flystay.com"
ADMIN_PASSWORD="AdminPassword123!"
ADMIN_NAME="مدير النظام"

# ===========================================
# AMADEUS (Flights Provider)
# ===========================================
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""
AMADEUS_ENV="production"

# ===========================================
# HOTELBEDS (Hotels Provider)
# ===========================================
HOTELBEDS_API_KEY=""
HOTELBEDS_SECRET=""
HOTELBEDS_ENV="production"

# ===========================================
# TAP Payments (Required)
# ===========================================
TAP_SECRET_KEY=""
TAP_PUBLIC_KEY=""
TAP_WEBHOOK_SECRET=""
TAP_ENV="production"

# ===========================================
# PACKAGES Provider (Optional)
# ===========================================
PACKAGES_API_KEY=""
PACKAGES_API_BASE_URL=""

# ===========================================
# INTERNAL INVENTORY (Chalets, Resthouses)
# ===========================================
INTERNAL_INVENTORY_ENABLED="false"

# ===========================================
# WhatsApp Integration
# ===========================================
WHATSAPP_SUPPORT_NUMBER="966500000000"
