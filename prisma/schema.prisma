generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  SUPPORT
  ADMIN
}

enum ServiceType {
  FLIGHT
  HOTEL
  PACKAGE
  CHALET
  RESTHOUSE
}

enum OrderStatus {
  NEW
  REVIEWING
  WAITING_USER
  OFFER_SENT
  CONFIRMED_MANUALLY
  CANCELLED
  CLOSED
}

enum ProviderType {
  FLIGHTS
  HOTELS
  PACKAGES
  CHALETS
  RESTHOUSES
  PAYMENTS
  INTERNAL
}

enum ProviderEnvironment {
  SANDBOX
  PRODUCTION
}

enum PaymentStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum BookingStatus {
  REQUESTED
  QUOTED
  PAYMENT_PENDING
  CONFIRMED
  FAILED
  CANCELLED
  REFUND_REQUIRED
  CLOSED
}

enum ProviderActionStatus {
  SUCCESS
  ERROR
  PENDING
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders        Order[]
  notifications Notification[]
  bookings      Booking[]
  payments      Payment[]
  auditLogs    AuditLog[]      @relation("AuditActor")
  providerLogs ProviderLog[]
  travelRequests TravelRequest[]

  @@map("users")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique @map("order_number")
  userId      String      @map("user_id")
  serviceType ServiceType @map("service_type")
  details     Json
  paymentStatus    PaymentStatus @default(CREATED) @map("payment_status")
  bookingStatus    BookingStatus @default(REQUESTED) @map("booking_status")
  finalAmount      Decimal?      @map("final_amount") @db.Decimal(12, 2)
  currency         String        @default("SAR")
  providerType     String?       @map("provider_type")
  providerName     String?       @map("provider_name")
  providerBookingId String?      @map("provider_booking_id")
  confirmationCode String?       @map("confirmation_code")
  idempotencyKey   String?       @unique @map("idempotency_key")
  status      OrderStatus @default(NEW)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusHistory OrderStatusHistory[]
  adminNotes    AdminNote[]
  bookings      Booking[]
  payments      Payment[]
  providerLogs  ProviderLog[]

  @@map("orders")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AdminNote {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  adminId   String   @map("admin_id")
  note      String
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("admin_notes")
}

model Booking {
  id                  String        @id @default(cuid())
  orderId             String        @map("order_id")
  userId              String        @map("user_id")
  providerType        ProviderType  @map("provider_type")
  providerName        String        @map("provider_name")
  providerBookingId   String?       @map("provider_booking_id")
  confirmationCode    String?       @map("confirmation_code")
  status              BookingStatus @default(REQUESTED)
  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("SAR")
  rawProviderResponse Json?         @map("raw_provider_response")
  idempotencyKey     String        @unique @map("idempotency_key")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Payment {
  id                  String        @id @default(cuid())
  orderId             String        @map("order_id")
  userId              String        @map("user_id")
  providerName        String        @default("Tap") @map("provider_name")
  providerPaymentId   String?       @map("provider_payment_id")
  checkoutUrl         String?       @map("checkout_url")
  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("SAR")
  status              PaymentStatus @default(CREATED)
  rawProviderResponse Json?         @map("raw_provider_response")
  idempotencyKey     String        @unique @map("idempotency_key")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model ProviderCredential {
  id           String             @id @default(cuid())
  providerType ProviderType       @map("provider_type")
  providerName String             @map("provider_name")
  enabled      Boolean            @default(true)
  environment  ProviderEnvironment @default(PRODUCTION)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("provider_credentials")
}

model ProviderLog {
  id             String               @id @default(cuid())
  userId         String?              @map("user_id")
  orderId        String?              @map("order_id")
  providerType   ProviderType         @map("provider_type")
  providerName   String              @map("provider_name")
  action         String
  status         ProviderActionStatus
  requestId      String?             @map("request_id")
  idempotencyKey String?             @map("idempotency_key")
  errorCode      String?             @map("error_code")
  errorMessage   String?             @map("error_message")
  createdAt      DateTime            @default(now()) @map("created_at")

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@map("provider_logs")
  @@index([userId])
  @@index([orderId])
  @@index([idempotencyKey])
}

model WebhookEvent {
  id                 String   @id @default(cuid())
  providerName       String   @map("provider_name")
  eventType          String   @map("event_type")
  eventId            String?  @unique @map("event_id")
  signatureVerified  Boolean  @default(false) @map("signature_verified")
  processed          Boolean  @default(false)
  rawPayload         Json?    @map("raw_payload")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("webhook_events")
  @@index([providerName, eventType])
  @@index([processed])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id")
  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent")
  details    Json?   @map("details")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model InventoryItem {
  id           String      @id @default(cuid())
  title        String
  serviceType  ServiceType @map("service_type")
  city         String
  description  String?     @db.Text
  images       Json?     @map("images")
  amenities    Json?     @map("amenities")
  capacity     Int
  bedrooms     Int         @default(1)
  bathrooms    Int         @default(1)
  ownerName    String?     @map("owner_name")
  ownerPhone   String?     @map("owner_phone")
  basePrice    Decimal     @db.Decimal(12, 2)
  serviceFee   Decimal     @default(0) @map("service_fee") @db.Decimal(12, 2)
  currency     String      @default("SAR")
  terms        String?     @db.Text
  active       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  availabilities InventoryAvailability[]

  @@map("inventory_items")
  @@index([serviceType, active])
  @@index([city])
}

model InventoryAvailability {
  id              String        @id @default(cuid())
  inventoryItemId String        @map("inventory_item_id")
  date            DateTime      @db.Date
  availableUnits  Int           @default(1) @map("available_units")
  priceOverride   Decimal?      @map("price_override") @db.Decimal(12, 2)
  blocked         Boolean       @default(false)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  item InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([inventoryItemId, date])
  @@map("inventory_availability")
  @@index([inventoryItemId, date])
}

model Offer {
  id          String   @id @default(cuid())
  title       String
  description String
  code        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("offers")
}

// Travel Encyclopedia Models

model TravelDestination {
  id                String   @id @default(cuid())
  slug              String   @unique
  cityAr            String   @map("city_ar")
  cityEn            String?  @map("city_en")
  countryAr         String   @map("country_ar")
  countryEn         String?  @map("country_en")
  regionAr          String?  @map("region_ar")
  descriptionAr     String   @map("description_ar")
  shortSummaryAr    String?  @map("short_summary_ar")
  heroImageUrl      String?  @map("hero_image_url")
  galleryImages     Json     @default("[]") @map("gallery_images")
  travelStyles      Json     @default("[]") @map("travel_styles")
  bestForAr         Json     @default("[]") @map("best_for_ar")
  notBestForAr      Json     @default("[]") @map("not_best_for_ar")
  popularAreasAr    Json     @default("[]") @map("popular_areas_ar")
  topActivitiesAr   Json     @default("[]") @map("top_activities_ar")
  suggestedDurations Json    @default("[]") @map("suggested_durations")
  budgetLevel       String   @default("MIXED") @map("budget_level")
  seasonNotesAr     String?  @map("season_notes_ar")
  airportInfoAr     String?  @map("airport_info_ar")
  transportNotesAr  String?  @map("transport_notes_ar")
  familyNotesAr     String?  @map("family_notes_ar")
  safetyNotesAr     String?  @map("safety_notes_ar")
  status            String   @default("ACTIVE")
  sourceType        String   @default("CURATED") @map("source_type")
  lastReviewedAt    DateTime? @map("last_reviewed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  areas     TravelArea[]
  activities TravelActivity[]
  templates TripTemplate[]
  travelRequests TravelRequest[]

  @@map("travel_destinations")
  @@index([slug])
  @@index([status])
  @@index([countryAr])
}

model TravelArea {
  id            String   @id @default(cuid())
  destinationId String   @map("destination_id")
  nameAr        String   @map("name_ar")
  nameEn        String?  @map("name_en")
  descriptionAr String?  @map("description_ar")
  bestForAr     Json     @default("[]") @map("best_for_ar")
  nearbyHighlightsAr Json @default("[]") @map("nearby_highlights_ar")
  budgetLevel   String?  @map("budget_level")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination TravelDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("travel_areas")
  @@index([destinationId])
}

model TravelActivity {
  id            String   @id @default(cuid())
  destinationId String   @map("destination_id")
  titleAr       String   @map("title_ar")
  category      String
  descriptionAr String?  @map("description_ar")
  durationHintAr String? @map("duration_hint_ar")
  familyFriendly Boolean @default(false) @map("family_friendly")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination TravelDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("travel_activities")
  @@index([destinationId])
  @@index([category])
}

model TripTemplate {
  id            String   @id @default(cuid())
  slug          String   @unique
  titleAr       String   @map("title_ar")
  serviceType   String   @map("service_type")
  destinationId String?  @map("destination_id")
  cityAr        String?  @map("city_ar")
  summaryAr     String   @map("summary_ar")
  idealFor      Json     @default("[]")
  durationDays  Int?     @map("duration_days")
  includesAr    Json     @default("[]") @map("includes_ar")
  itinerary     Json     @default("[]")
  budgetLevel   String   @default("MIXED") @map("budget_level")
  requirementsAr Json    @default("[]") @map("requirements_ar")
  disclaimersAr Json     @default("[]") @map("disclaimers_ar")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  destination    TravelDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  travelRequests TravelRequest[]

  @@map("trip_templates")
  @@index([slug])
  @@index([status])
  @@index([serviceType])
}

model StayGuide {
  id                  String   @id @default(cuid())
  type                String
  cityAr              String   @map("city_ar")
  titleAr             String   @map("title_ar")
  descriptionAr       String?  @map("description_ar")
  capacityHintAr      String?  @map("capacity_hint_ar")
  featuresAr          Json     @default("[]") @map("features_ar")
  idealFor            Json     @default("[]")
  hasPoolHint         Boolean? @map("has_pool_hint")
  hasOutdoorSeatingHint Boolean? @map("has_outdoor_seating_hint")
  budgetLevel         String   @default("MID") @map("budget_level")
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("stay_guides")
  @@index([type])
  @@index([status])
  @@index([cityAr])
}

model TravelRequest {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  sourceType    String   @default("MANUAL") @map("source_type")
  serviceType   String   @map("service_type")
  destinationId String?  @map("destination_id")
  templateId    String?  @map("template_id")
  cityAr        String?  @map("city_ar")
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  guests        Int?     @map("guests")
  rooms         Int?     @map("rooms")
  budgetLevel   String?  @map("budget_level")
  notes         String?  @map("notes")
  details       Json     @default("{}")
  status        String   @default("NEW")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination TravelDestination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  template    TripTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@map("travel_requests")
  @@index([userId])
  @@index([status])
}
