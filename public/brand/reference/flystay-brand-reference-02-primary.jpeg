<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="heroGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#2B2D31;stop-opacity:0.9"/>
      <stop offset="100%" style="stop-color:#2B2D31;stop-opacity:0.7"/>
    </linearGradient>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#CDB68B"/>
      <stop offset="100%" style="stop-color:#D4C49A"/>
    </linearGradient>
  </defs>
  <!-- Background -->
  <rect fill="#F8F6F1" width="1920" height="1080"/>
  <!-- Header -->
  <rect fill="#2B2D31" width="1920" height="100"/>
  <text x="960" y="65" fill="#F8F6F1" font-family="serif" font-size="42" font-weight="600" text-anchor="middle">FlyStay</text>
  <rect fill="#CDB68B" x="100" y="30" width="80" height="40" rx="8"/>
  <rect fill="#CDB68B" x="1740" y="30" width="80" height="40" rx="8"/>
  <!-- Hero Section -->
  <rect fill="url(#heroGrad)" x="0" y="100" width="1920" height="500"/>
  <text x="960" y="300" fill="#F8F6F1" font-family="sans-serif" font-size="64" font-weight="600" text-anchor="middle">رحلتك القادمة تبدأ من هنا</text>
  <text x="960" y="380" fill="#CDB68B" font-family="serif" font-size="24" text-anchor="middle">Your Next Journey Begins Here</text>
  <rect fill="#CDB68B" x="810" y="420" width="300" height="60" rx="30"/>
  <text x="960" y="458" fill="#2B2D31" font-family="sans-serif" font-size="20" font-weight="600" text-anchor="middle">استكشف الوجهات</text>
  <!-- Services Cards -->
  <rect fill="#E7E3DC" x="80" y="650" width="400" height="200" rx="24"/>
  <rect fill="#CDB68B" x="120" y="700" width="80" height="80" rx="16"/>
  <text x="160" y="755" fill="#2B2D31" font-family="sans-serif" font-size="48" text-anchor="middle">✈</text>
  <text x="300" y="740" fill="#2B2D31" font-family="sans-serif" font-size="24" font-weight="600" text-anchor="middle">طيران</text>
  <text x="300" y="780" fill="#5C5D60" font-family="sans-serif" font-size="16" text-anchor="middle">حجز رحلات طيران</text>
  <rect fill="#E7E3DC" x="520" y="650" width="400" height="200" rx="24"/>
  <rect fill="#CDB68B" x="560" y="700" width="80" height="80" rx="16"/>
  <text x="600" y="755" fill="#2B2D31" font-family="sans-serif" font-size="48" text-anchor="middle">🏨</text>
  <text x="740" y="740" fill="#2B2D31" font-family="sans-serif" font-size="24" font-weight="600" text-anchor="middle">فنادق</text>
  <text x="740" y="780" fill="#5C5D60" font-family="sans-serif" font-size="16" text-anchor="middle">أفضل الفنادق</text>
  <rect fill="#E7E3DC" x="960" y="650" width="400" height="200" rx="24"/>
  <rect fill="#CDB68B" x="1000" y="700" width="80" height="80" rx="16"/>
  <text x="1040" y="755" fill="#2B2D31" font-family="sans-serif" font-size="48" text-anchor="middle">📦</text>
  <text x="1180" y="740" fill="#2B2D31" font-family="sans-serif" font-size="24" font-weight="600" text-anchor="middle">باقات</text>
  <text x="1180" y="780" fill="#5C5D60" font-family="sans-serif" font-size="16" text-anchor="middle">باقات سياحية</text>
  <rect fill="#E7E3DC" x="1400" y="650" width="400" height="200" rx="24"/>
  <rect fill="#CDB68B" x="1440" y="700" width="80" height="80" rx="16"/>
  <text x="1480" y="755" fill="#2B2D31" font-family="sans-serif" font-size="48" text-anchor="middle">🎁</text>
  <text x="1620" y="740" fill="#2B2D31" font-family="sans-serif" font-size="24" font-weight="600" text-anchor="middle">عروض</text>
  <text x="1620" y="780" fill="#5C5D60" font-family="sans-serif" font-size="16" text-anchor="middle">عروض حصرية</text>
  <!-- Bottom Nav -->
  <rect fill="#F8F6F1" x="0" y="980" width="1920" height="100"/>
  <rect fill="#2B2D31" x="0" y="970" width="1920" height="3" fill="#CDB68B"/>
  <circle fill="#CDB68B" cx="300" cy="1030" r="24"/>
  <circle fill="#9A9A9C" cx="620" cy="1030" r="24"/>
  <circle fill="#9A9A9C" cx="960" cy="1030" r="24"/>
  <circle fill="#9A9A9C" cx="1300" cy="1030" r="24"/>
  <circle fill="#9A9A9C" cx="1620" cy="1030" r="24"/>
  <!-- Footer -->
  <text x="1920" y="1060" fill="#9A9A9C" font-family="sans-serif" font-size="14" text-anchor="end">PRIMARY REFERENCE - Luxury Travel Minimal - FlyStay 2026</text>
</svg>
